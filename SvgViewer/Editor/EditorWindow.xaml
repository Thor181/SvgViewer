<Window x:Class="SvgViewer.Editor.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SvgViewer.Editor"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        xmlns:vm="clr-namespace:SvgViewer.Editor"
        mc:Ignorable="d"
        Title="EditorWindow"
        Height="450"
        Width="800">

    <Window.DataContext>
        <vm:EditorViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <RichTextBox x:Name="CodeTextBox" HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch">
            </RichTextBox>
        </Grid>

        <GridSplitter Grid.Column="1"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Width="3" />

        <Grid Grid.Column="2">
            <svgc:SvgViewbox Source="{Binding Data}"
                             Margin="5"></svgc:SvgViewbox>
        </Grid>

    </Grid>
</Window>
